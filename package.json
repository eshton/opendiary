{
  "name": "opendiary",
  "version": "0.0.0",
  "private": true,
  "description": "Privacy-first personal diary. Your entries never leave your computer.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:cli": "bun run --filter '@opendiary/cli' dev",
    "dev:web": "bun run --filter '@opendiary/web' dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.0",
    "typescript": "^5.6.0"
  }
}
